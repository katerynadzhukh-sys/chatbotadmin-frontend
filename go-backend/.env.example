# ── Backend configuration ───────────────────────────────────────────────────
# Copy to .env and fill in. docker-compose injects DATABASE_URL / REDIS_HOST.

# Runtime
PORT=8080
# Set to "production" on staging/prod. In production ALLOWED_ORIGINS is required.
GO_ENV=development

# Database (overridden by docker-compose to point at the postgres service)
DATABASE_URL=postgres://chatbotadmin:chatbotadmin@localhost:5432/chatbotadmin?sslmode=disable
POSTGRES_PASSWORD=chatbotadmin

# Redis (overridden by docker-compose to point at the redis service)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT signing secret — REQUIRED, at least 32 characters.
JWT_SECRET=change-me-to-at-least-32-characters-long

# Encrypts the OIDC client_secret at rest. REQUIRED when an OIDC client_secret
# is configured. Must be base64 of exactly 32 bytes, e.g.:
#   openssl rand -base64 32
AUTH_PROVIDER_SECRET_KEY=

# CORS allowlist (comma-separated). Required in production.
ALLOWED_ORIGINS=http://localhost:5173

# Seed admin (superadmin). Leave ADMIN_PASSWORD empty to skip seeding.
# Local-dev default (also baked into docker-compose) is admin / password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password

# ── Model proxy (HRZ OpenAI-compatible endpoint) ─────────────────────────────
KI_API_KEY=
KI_BASE_URL=https://api.hrz.uni-giessen.de/v1

# ── OIDC / Keycloak (server-side broker) ─────────────────────────────────────
# Leave these UNSET for local dev (you get the admin / password login). Set them
# on staging/prod to enable SSO; once an OIDC provider is active the login page
# offers SSO only — the password form is hidden and local password login is
# rejected for everyone (no breakglass). The FIRST user to log in via SSO is
# provisioned as superadmin (bootstrap); everyone after is a normal user — so
# log in yourself right after enabling OIDC. The backend is a CONFIDENTIAL OIDC
# client (it holds the client_secret and runs the code exchange). Keycloak
# client must be:
#   - Client authentication: ON (confidential)
#   - Standard flow: enabled; PKCE: S256
#   - Valid Redirect URIs: <backend-origin>/api/auth/oidc/callback
#   - Valid Post Logout Redirect URIs: <frontend-origin>/login
#
# The four values below are what the HRZ hands out (the JLU "jlu" realm):
#   OIDC_IDP            — the IdP discovery URL (…/.well-known/openid-configuration).
#                         The backend strips the well-known suffix to the issuer.
#   OIDC_CLIENT_ID      — the registered client.
#   OIDC_CLIENT_SECRET  — the confidential client secret (keep out of git).
#   OIDC_LOGOUT_URI     — the IdP end-session endpoint (RP-initiated logout).
OIDC_PROVIDER_NAME=Uni Gießen
OIDC_IDP=https://login.uni-giessen.de/realms/jlu/.well-known/openid-configuration
OIDC_CLIENT_ID=chatwidgets
OIDC_CLIENT_SECRET=
OIDC_LOGOUT_URI=https://login.uni-giessen.de/realms/jlu/protocol/openid-connect/logout
OIDC_SCOPES=openid profile email
# Where Keycloak redirects after login — must be the BACKEND callback. On
# staging this is https://sv90073.hrz.uni-giessen.de/api/auth/oidc/callback
OIDC_REDIRECT_URI=http://localhost:8080/api/auth/oidc/callback
# Frontend URL the callback bounces to with the JWT in the fragment (#oidc=...).
# On staging: https://sv90073.hrz.uni-giessen.de/auth/callback
OIDC_SUCCESS_REDIRECT=http://localhost:5173/auth/callback
# Where the IdP sends the browser back after logout (must be pre-registered as a
# Post Logout Redirect URI). On staging: https://sv90073.hrz.uni-giessen.de/login
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/login
