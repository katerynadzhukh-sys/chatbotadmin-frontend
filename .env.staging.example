# ── Full-stack STAGING env (sv90073.hrz.uni-giessen.de) ──────────────────────
# Read by the ROOT docker-compose.yml (frontend + backend + Postgres + Redis).
# Copy to .env on the staging host and fill in every FILL_IN value:
#   cp .env.staging.example .env
# Then:  docker compose up -d --build chatbotadmin-frontend backend
#
# After the stack is up, log in via SSO IMMEDIATELY — the first SSO user is
# provisioned as superadmin (see docs/AUTHENTICATION.md → Roles & first-login
# bootstrap).

# Production mode: fail-closed token revocation; ALLOWED_ORIGINS becomes required.
GO_ENV=production

# Postgres password (the bundled postgres service is created with it, and the
# backend's DATABASE_URL is assembled from it by docker-compose).
POSTGRES_PASSWORD=FILL_IN_strong_db_password

# JWT signing secret — ≥32 chars. openssl rand -base64 48
JWT_SECRET=FILL_IN_jwt_secret_at_least_32_chars

# Encrypts the OIDC client_secret at rest — REQUIRED (a client secret is set).
# Must be base64 of exactly 32 bytes: openssl rand -base64 32
AUTH_PROVIDER_SECRET_KEY=FILL_IN_base64_32_bytes

# CORS allowlist — the staging origin.
ALLOWED_ORIGINS=https://sv90073.hrz.uni-giessen.de

# Seed admin (local superadmin). With OIDC active this account CANNOT log in
# (local password is disabled); leave ADMIN_PASSWORD empty to skip seeding it.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=FILL_IN_strong_admin_password

# Model proxy (HRZ OpenAI-compatible endpoint).
KI_API_KEY=FILL_IN_hrz_api_key
KI_BASE_URL=https://api.hrz.uni-giessen.de/v1

# ── OIDC / Keycloak (JLU "jlu" realm, confidential client `chatwidgets`) ──────
# Keycloak client must have:
#   - Client authentication: ON (confidential); Standard flow + PKCE S256
#   - Valid Redirect URIs:             https://sv90073.hrz.uni-giessen.de/api/auth/oidc/callback
#   - Valid Post Logout Redirect URIs: https://sv90073.hrz.uni-giessen.de/login
OIDC_PROVIDER_NAME=Uni Gießen
OIDC_IDP=https://login.uni-giessen.de/realms/jlu/.well-known/openid-configuration
OIDC_CLIENT_ID=chatwidgets
OIDC_CLIENT_SECRET=FILL_IN_keycloak_client_secret
OIDC_LOGOUT_URI=https://login.uni-giessen.de/realms/jlu/protocol/openid-connect/logout
OIDC_REDIRECT_URI=https://sv90073.hrz.uni-giessen.de/api/auth/oidc/callback
OIDC_SUCCESS_REDIRECT=https://sv90073.hrz.uni-giessen.de/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=https://sv90073.hrz.uni-giessen.de/login

# ── Backend outbound proxy ───────────────────────────────────────────────────
# If the staging host reaches the internet only via the HRZ proxy, set these so
# the backend can reach the IdP (login.uni-giessen.de) and the HRZ model API.
BACKEND_HTTP_PROXY=http://10.60.3.254:3128
BACKEND_HTTPS_PROXY=http://10.60.3.254:3128
BACKEND_NO_PROXY=localhost,127.0.0.1,postgres,redis,backend

# NOTE: if staging binds HTTPS on :442 instead of :443, append :442 to every
# sv90073 URL above (and register the :442 variants in Keycloak).
