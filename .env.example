# Base URL for the chatbot widget (where widget.js is hosted)
# For production: https://sv90073.hrz.uni-giessen.de/
# For local development: http://localhost:5500
VITE_WIDGET_BASE_URL=https://sv90073.hrz.uni-giessen.de/

# URL of the mock widget portal (standalone test site that embeds the widget),
# linked from the admin user menu (admins only). Leave UNSET (default): the app
# then follows the CURRENT deployment's host on the widget-test-site port
# (<protocol>//<host>:8082/) — a cross-origin URL, which is the whole point (it
# exercises the real cross-origin embed + login). Do NOT hardcode a single
# environment here. Set it only if your portal lives on a different host/port.
# VITE_WIDGET_PORTAL_URL=

# ── Backend ──────────────────────────────────────────────────────────────────
# All /api routes (auth, users, API keys, and the model proxy /api/models +
# /api/chat) are served by the Go backend in ./go-backend. Authentication,
# the HRZ API key, and the Keycloak OIDC client secret all live there now —
# see go-backend/.env.example. Nothing sensitive is bundled into the SPA.

# Base URL of the backend. Leave EMPTY for same-origin: the Vite dev server
# proxies /api to BACKEND_ORIGIN, and in production nginx reverse-proxies /api.
# Only set this for a cross-origin backend deployment.
VITE_API_BASE_URL=

# Dev-only: where `vite dev` proxies /api (defaults to http://localhost:8080).
BACKEND_ORIGIN=http://localhost:8080
